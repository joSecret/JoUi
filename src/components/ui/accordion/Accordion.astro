---
import './accordion.css';

interface AccordionItem {
  id?: string;
  title: string;
  content: string;
  open?: boolean;
}

interface Props {
  items?: AccordionItem[];
  flush?: boolean;
  stayOpen?: boolean;
  iconPosition?: 'left' | 'right' | 'none';
  classes?: string[];
  attrs?: Record<string, unknown>;
}

const { items = [], flush = false, stayOpen = false, iconPosition = 'right', classes = [], attrs = {} } = Astro.props;

const accordionName = `accordion-${Math.random().toString(36).slice(2, 7)}`;

const classList = [
  'accordion',
  flush && 'accordion-flush',
  ...classes,
].filter(Boolean);

const chevronSvg = `<svg viewBox="0 0 17 17" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M16.354 5.075l-7.855 7.854-7.853-7.854 0.707-0.707 7.145 7.146 7.148-7.147 0.708 0.708z" fill="currentColor"/></svg>`;
---

<div class:list={classList} {...attrs}>
  {items.length > 0 ? (
    items.map((item) => (
      <details class="accordion-item" open={item.open || false} id={item.id || undefined} name={!stayOpen ? accordionName : undefined}>
        <summary>
          {iconPosition !== 'left' && <span>{item.title}</span>}
          {iconPosition !== 'none' && (
            <div class="accordion-icon">
              <Fragment set:html={chevronSvg} />
            </div>
          )}
          {iconPosition === 'left' && <span>{item.title}</span>}
        </summary>
        <div class="accordion-body">
          <Fragment set:html={item.content} />
        </div>
      </details>
    ))
  ) : (
    <slot />
  )}
</div>
