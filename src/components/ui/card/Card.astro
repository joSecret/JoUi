---
import './card.css';

interface Props {
  color?: string | null;
  horizontal?: boolean;
  shadow?: boolean | 'lg';
  classes?: string[];
  attrs?: Record<string, unknown>;
}

const {
  color = null,
  horizontal = false,
  shadow = false,
  classes = [],
  attrs = {},
} = Astro.props;

const classList = [
  'card',
  color && `card-${color}`,
  horizontal && 'card-horizontal',
  shadow === 'lg' ? 'card-shadow-lg' : shadow ? 'card-shadow' : null,
  ...classes,
].filter(Boolean);
---

<div class:list={classList} {...attrs}>
  <slot />
</div>
