---
import './check-radio.css';

interface Props {
  type?: 'checkbox' | 'radio' | 'switch';
  id?: string;
  name?: string;
  label?: string;
  checked?: boolean;
  disabled?: boolean;
  inline?: boolean;
  value?: string;
  required?: boolean;
  classes?: string[];
  attrs?: Record<string, unknown>;
}

const {
  type = 'checkbox',
  id,
  name,
  label,
  checked = false,
  disabled = false,
  inline = false,
  value,
  required = false,
  classes = [],
  attrs = {},
} = Astro.props;

const inputId = id || `check-${Math.random().toString(36).slice(2, 7)}`;
const inputType = type === 'switch' ? 'checkbox' : type;

const wrapperClasses = [
  'form-check',
  type === 'switch' && 'form-switch',
  inline && 'form-check-inline',
  ...classes,
].filter(Boolean);
---

<div class:list={wrapperClasses}>
  <input
    class="form-check-input"
    type={inputType}
    id={inputId}
    name={name}
    value={value}
    checked={checked || undefined}
    disabled={disabled || undefined}
    required={required || undefined}
    role={type === 'switch' ? 'switch' : undefined}
    {...attrs}
  />
  {label && <label class="form-check-label" for={inputId}>{label}</label>}
</div>
