---
import './pager.css';

interface PagerItem {
  href: string;
  text?: string;
}

interface PagerItems {
  first?: PagerItem;
  previous?: PagerItem;
  pages?: Record<number, PagerItem>;
  next?: PagerItem;
  last?: PagerItem;
}

interface Props {
  alignment?: 'start' | 'end' | 'center' | 'vertical' | null;
  showFirst?: boolean;
  showLast?: boolean;
  showEllipsis?: boolean;
  items?: PagerItems | null;
  current?: number | null;
  ellipses?: { previous?: boolean; next?: boolean } | null;
  classes?: string[];
  attrs?: Record<string, unknown>;
}

const {
  alignment = null,
  showFirst = true,
  showLast = true,
  showEllipsis = true,
  items = null,
  current = null,
  ellipses = null,
  classes = [],
  attrs = {},
} = Astro.props;

const classList = [
  'c--pager',
  alignment && `is--align-${alignment}`,
  ...classes,
].filter(Boolean);
---

{items && (
  <nav class:list={classList} role="navigation" aria-label="Pagination" {...attrs}>
    <ul class="pager__items">
      {items.first && showFirst && (
        <li>
          <a href={items.first.href} title="Go to first page" class="page-link">
            <span class="visually-hidden">First page</span>
            <span aria-hidden="true">{items.first.text ?? '« First'}</span>
          </a>
        </li>
      )}

      {items.previous && (
        <li>
          <slot name="pager-previous">
            <a href={items.previous.href} title="Go to previous page" rel="prev" class="page-link">
              <span class="visually-hidden">Previous page</span>
              <span aria-hidden="true">{items.previous.text ?? '‹ Previous'}</span>
            </a>
          </slot>
        </li>
      )}

      {ellipses?.previous && showEllipsis && (
        <li role="presentation">
          <span class="page-link">&hellip;</span>
        </li>
      )}

      {items.pages && Object.entries(items.pages).map(([key, item]) => (
        <li>
          <a
            href={item.href}
            title={current === Number(key) ? 'Current page' : `Go to page ${key}`}
            class="page-link"
            aria-current={current === Number(key) ? 'page' : undefined}
          >
            <span class="visually-hidden">{current === Number(key) ? 'Current page' : 'Page'}</span>
            {key}
          </a>
        </li>
      ))}

      {ellipses?.next && showEllipsis && (
        <li role="presentation">
          <span class="page-link">&hellip;</span>
        </li>
      )}

      {items.next && (
        <li>
          <slot name="pager-next">
            <a href={items.next.href} title="Go to next page" rel="next" class="page-link">
              <span class="visually-hidden">Next page</span>
              <span aria-hidden="true">{items.next.text ?? 'Next ›'}</span>
            </a>
          </slot>
        </li>
      )}

      {items.last && showLast && (
        <li>
          <a href={items.last.href} title="Go to last page" class="page-link">
            <span class="visually-hidden">Last page</span>
            <span aria-hidden="true">{items.last.text ?? 'Last »'}</span>
          </a>
        </li>
      )}
    </ul>
  </nav>
)}
