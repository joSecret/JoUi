{#
/**
 * @file
 * Pager component.
 *
 * Available variations:
 * - pager_alignment (null|start|end|center|vertical) (default: null)
 *
 * Available values:
 * - pager_show_first (boolean) (default: true)
 * - pager_show_last (boolean) (default: true)
 * - pager_show_ellipsis (boolean) (default: true)
 * - pager_items (object|null) Pager items (first, previous, pages, next, last)
 * - pager_current (integer|null) Current active page number
 * - pager_ellipses (object|null) Ellipses indicators
 *
 * Available Utility classes -> uc
 * - pager_uc (array) (default: [])
 *
 * Available attributes -> att
 * - pager_att (Drupal\Core\Template\Attribute)
 *
 * Available slots:
 * - slot_pager_previous: Previous page link content
 * - slot_pager_next: Next page link content
 */
#}

{# Set default values #}
{% set pager_alignment = pager_alignment|default(null) %}
{% set pager_show_first = pager_show_first|default(true) %}
{% set pager_show_last = pager_show_last|default(true) %}
{% set pager_show_ellipsis = pager_show_ellipsis|default(true) %}
{% set pager_items = pager_items|default(items) %}
{% set pager_current = pager_current|default(current) %}
{% set pager_ellipses = pager_ellipses|default(ellipses) %}

{# Create attributes #}
{% set pager_att = pager_att|default(attributes) ?: create_attribute() %}

{# Build classes array #}
{%
  set pager_classes = [
    'c--pager',
    pager_alignment ? 'is--align-' ~ pager_alignment : '',
  ]|merge(pager_uc ?: [])
%}

{%
  set pager_list_classes = [
    'pager__items',
    'js-pager__items',
  ]
%}

{# Change attributes #}

{# Render component #}
{% apply spaceless %}

{% if pager_items %}
  <nav {{ pager_att.addClass(pager_classes) }} role="navigation" aria-label="{{ 'Pagination'|t }}">
    <ul class="{{ pager_list_classes|join(' ') }}">
      {# Print first item if we are not on the first page. #}
      {% if pager_items.first and pager_show_first %}
        <li class="page-item pager__item pager__item--first">
          <a href="{{ pager_items.first.href }}" title="{{ 'Go to first page'|t }}" {{ pager_items.first.attributes|without('href', 'title') }} class="page-link">
            <span class="visually-hidden">{{ 'First page'|t }}</span>
            <span aria-hidden="true">{{ pager_items.first.text|default('« First'|t) }}</span>
          </a>
        </li>
      {% endif %}

      {# Print previous item if we are not on the first page. #}
      {% if pager_items.previous %}
        <li class="page-item pager__item pager__item--previous">
          {% block slot_pager_previous %}
            <a href="{{ pager_items.previous.href }}" title="{{ 'Go to previous page'|t }}" rel="prev" {{ pager_items.previous.attributes|without('href', 'title', 'rel') }} class="page-link">
              <span class="visually-hidden">{{ 'Previous page'|t }}</span>
              <span aria-hidden="true">{{ pager_items.previous.text|default('‹ Previous'|t) }}</span>
            </a>
          {% endblock %}
        </li>
      {% endif %}

      {# Add an ellipsis if there are further previous pages. #}
      {% if pager_ellipses.previous and pager_show_ellipsis %}
        <li class="page-item pager__item pager__item--ellipsis disabled" role="presentation">
          <span class="page-link">&hellip;</span>
        </li>
      {% endif %}

      {# Now generate the actual pager piece. #}
      {% for key, item in pager_items.pages %}
        <li class="page-item pager__item{{ pager_current == key ? ' is-active active' : '' }}">
          {% if pager_current == key %}
            {% set title = 'Current page'|t %}
          {% else %}
            {% set title = 'Go to page @key'|t({'@key': key}) %}
          {% endif %}
          <a href="{{ item.href }}" title="{{ title }}" {{ item.attributes|without('href', 'title') }} class="page-link">
            <span class="visually-hidden">
              {{ pager_current == key ? 'Current page'|t : 'Page'|t }}
            </span>
            {{- key -}}
          </a>
        </li>
      {% endfor %}

      {% if pager_items.current and (pager_items.previous or pager_items.next) %}
        <li class="page-item disabled">
          <span class="page-link">
            {{ 'Page'|t ~ pager_items.current }}
          </span>
        </li>
      {% endif %}

      {# Add an ellipsis if there are further next pages. #}
      {% if pager_ellipses.next and pager_show_ellipsis %}
        <li class="page-item pager__item pager__item--ellipsis disabled" role="presentation">
          <span class="page-link">&hellip;</span>
        </li>
      {% endif %}

      {# Print next item if we are not on the last page. #}
      {% if pager_items.next %}
        <li class="page-item pager__item pager__item--next">
          {% block slot_pager_next %}
            <a href="{{ pager_items.next.href }}" title="{{ 'Go to next page'|t }}" rel="next" {{ pager_items.next.attributes|without('href', 'title', 'rel') }} class="page-link">
              <span class="visually-hidden">{{ 'Next page'|t }}</span>
              <span aria-hidden="true">{{ pager_items.next.text|default('Next ›'|t) }}</span>
            </a>
          {% endblock %}
        </li>
      {% endif %}

      {# Print last item if we are not on the last page. #}
      {% if pager_items.last and pager_show_last %}
        <li class="page-item pager__item pager__item--last">
          <a href="{{ pager_items.last.href }}" title="{{ 'Go to last page'|t }}" {{ pager_items.last.attributes|without('href', 'title') }} class="page-link">
            <span class="visually-hidden">{{ 'Last page'|t }}</span>
            <span aria-hidden="true">{{ pager_items.last.text|default('Last »'|t) }}</span>
          </a>
        </li>
      {% endif %}
    </ul>
  </nav>
{% endif %}

{% endapply %}
