---
import './progress.css';

interface Props {
  value?: number;
  color?: string;
  striped?: boolean;
  animated?: boolean;
  label?: string | boolean;
  height?: string;
  classes?: string[];
  attrs?: Record<string, unknown>;
}

const {
  value = 0,
  color = null,
  striped = false,
  animated = false,
  label = false,
  height = null,
  classes = [],
  attrs = {},
} = Astro.props;

const clamped = Math.min(100, Math.max(0, value));
const isStriped = striped || animated;
const labelText = label === true ? `${clamped}%` : (label || '');

const wrapperClasses = [
  'progress',
  color && `progress-${color}`,
  ...classes,
].filter(Boolean);

const barClasses = [
  'progress-bar',
  isStriped && 'progress-bar-striped',
  animated && 'progress-bar-animated',
].filter(Boolean);

const wrapperStyle = height ? `--prog_h: ${height};` : undefined;
---

<div
  class:list={wrapperClasses}
  role="progressbar"
  aria-valuenow={clamped}
  aria-valuemin={0}
  aria-valuemax={100}
  aria-label={labelText || `${clamped}%`}
  style={wrapperStyle}
  {...attrs}
>
  <div class:list={barClasses} style={`width: ${clamped}%`}>
    {labelText && <span>{labelText}</span>}
  </div>
</div>
