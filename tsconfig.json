{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "strictNullChecks": true,
    "paths": {
      "@c/*": ["./src/components/*"],
      "@ui/*": ["./src/components/ui/*"],
      "@bl/*": ["./src/components/blocks/*"],
      "@l/*": ["./src/layouts/*"],
      "@s/*": ["./src/styles/*"],
      "@p/*": ["./src/pages/*"],
      "@lib/*": ["./src/lib/*"]
    }
  }
}
